# Environment variable template / 环境变量模板
# This repository does not auto-load `.env` by itself.
# Local development:
# 1) copy this file to `.env` for reference only, and
# 2) export the variables in your shell, or configure them in your deploy platform.

# Frontend / build-time injection
# Used by `.eleventy.js` to inject a default proxy origin into the transcription page.
CTEXT_PROXY_ORIGIN=

# Standalone CText proxy server / 独立代理服务
PORT=8787
HOST=0.0.0.0
CTEXT_PROXY_ALLOW_ORIGIN=*

# Middleware fetch behavior / CText 抓取行为
CTEXT_FETCH_MODE=browser
CTEXT_REQUEST_GAP_MS=120
CTEXT_GLOBAL_GAP_MS=1200
CTEXT_REQUEST_TIMEOUT_MS=15000
CTEXT_CACHE_TTL_MS=86400000
CTEXT_MAX_VARIANTS=12
CTEXT_MAX_VARIANT_ATTEMPTS=2
CTEXT_REQUIRE_STATS_GROUPS=1
CTEXT_INCLUDE_SINGLE_CHAR_VARIANTS=0
CTEXT_SINGLE_CHAR_FALLBACK_ON_EMPTY=1
CTEXT_SINGLE_CHAR_FALLBACK_MAX=2
CTEXT_SKIP_STATS=0

# Static cache builder / 静态缓存构建
CTEXT_CACHE_BASE=http://127.0.0.1:8080
CTEXT_CACHE_OUT=tmp/ctext-static-build/ctext-cache.candidate.json
CTEXT_CACHE_REPORT=tmp/ctext-static-build/ctext-cache.report.json
CTEXT_CACHE_PUBLISH_OUT=static/ctext-cache.json
CTEXT_CACHE_DELAY_MS=220
CTEXT_CACHE_TIMEOUT_MS=30000
CTEXT_CACHE_INCLUDE_NON_CJK=0
CTEXT_CACHE_MAPPED_TEXT=
CTEXT_CACHE_FORCE_REFRESH=1
CTEXT_CACHE_TRANSPORT=curl
